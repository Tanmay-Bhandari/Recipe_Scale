# Copy this file to .env.local and fill in your values. Do NOT commit secrets.

# Firebase (client-safe)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase admin (server-only) - recommended: set FIREBASE_ADMIN_CREDENTIALS to the full
# service-account JSON string (minified or base64-encoded). Example (do not commit):
# FIREBASE_ADMIN_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"..."}
# OR set FIREBASE_ADMIN_KEY_BASE64 to the base64-encoded JSON: base64 -w0 service-account.json
FIREBASE_ADMIN_CREDENTIALS=
FIREBASE_ADMIN_KEY_BASE64=

# Alternative separated fields
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Database (if used)
DATABASE_URL=postgresql://username:password@localhost:5432/your_database_name

# Optional: external server base (e.g. https://recipe-scale.onrender.com)
# Use `NEXT_PUBLIC_API_URL` to point frontend API calls to Render.
NEXT_PUBLIC_API_URL=https://recipe-scale.onrender.com
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Server-side Firebase Admin placeholders (set these on your Render service; do NOT commit real credentials)
# Example values:
# FIREBASE_PROJECT_ID=recipescale-4ba26
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@recipescale-4ba26.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_YOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n
