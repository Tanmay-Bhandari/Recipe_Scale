# Copy this file to .env.local and fill values
# Stringify the full service account JSON on one line (escape newlines)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...","client_id":"..."}
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
